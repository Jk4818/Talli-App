# Firebase Configuration
# You can get these values from your Firebase project settings
# under "Project settings" > "General" > Your app.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Invite-Only Signup Allowlist
# A comma-separated list of lowercase email addresses that are allowed to create an account.
# If this variable is not set or is empty, no one will be able to sign up.
# Example: EMAIL_ALLOWLIST="user1@example.com,user2@example.com"
EMAIL_ALLOWLIST=
