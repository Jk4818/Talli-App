# Firebase Project Configuration - copy these from your Firebase project settings
# and place them in a .env.local file.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Beta User Allowlist - comma-separated list of emails.
# If this is empty, all authenticated users will be allowed.
BETA_USERS_ALLOWLIST=
